<link name="hand_tcp"></link>

  
<joint name="roarm_base_link_to_link1" type="revolute">
  <origin xyz="0.0100000008759151 0 0.123059270461044" rpy="0 0 0" />
  <parent link="roarm_base_link" />
  <child link="link1" />
  <axis xyz="0 0 1" />
  <limit lower="-3.1416" upper="3.1416" effort="1000" velocity="1.0" />
</joint>

<joint name="link1_to_link2" type="revolute">
  <origin xyz="0 0 0" rpy="-1.5708 -1.5708 0" />
  <parent link="link1" />
  <child link="link2" />
  <axis xyz="0 0 1" />
  <limit lower="-1.5708" upper="1.5708" effort="1000" velocity="1.0" />
</joint>

<joint name="link2_to_link3" type="revolute">
  <origin xyz="0.236815132922094 0.0300023995170449 0" rpy="0 0 1.5708" />
  <parent link="link2" />
  <child  link="link3" />
  <axis xyz="0 0 1" />
  <limit lower="-1" upper="2.95" effort="1000" velocity="1.0" />
</joint>

<joint name="link3_to_link4" type="fixed">
  <origin xyz="-0.003266 -0.21599 -0.00560" rpy="0 0 -1.5708" />
  <parent link="link3" />
  <child link="link4" />
  <axis xyz="0 0 1" />
  <limit lower="-1.5" upper="1.5" effort="1000" velocity="1.0" />
</joint> 

<joint name="link4_to_link5" type="revolute">
  <origin xyz="0.0835 -0.0 -0.000" rpy="1.5708 0 0" />
  <parent link="link4" />
  <child link="link5" />
  <axis xyz="1 0 0" />
  <limit lower="-1.5" upper="1.5" effort="1000" velocity="1.0" />
</joint>

<joint name="link5_to_gripper" type="revolute">
  <origin xyz="0.0653 0 -0.00083" rpy="1.5708 0 0" />
  <parent link="link5" />
  <child link="gripper" />
  <axis xyz="0 0 1" />
  <limit lower="-3" upper="3" effort="1000" velocity="1.0" />
</joint> 



<joint name="link3_to_hand_tcp" type="fixed">
  <origin xyz="0.002 -0.2802 0" rpy="1.5708 0 -1.5708" />
  <parent link="link3" />
  <child link="hand_tcp" />
  <axis xyz="0 0 0" />
</joint>
  
</robot>
