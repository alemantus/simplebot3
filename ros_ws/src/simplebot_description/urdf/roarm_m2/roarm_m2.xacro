<link name="gripper">
  <inertial>
    <origin xyz="0.0 0 0.0" rpy="0 0 0" />
    <mass value="0.0028708" />
    <inertia ixx="5.23216E-07" ixy="0" ixz="0" iyy="1.82071E-06" iyz="0" izz="1.60231E-06" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/Gripper-B.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
