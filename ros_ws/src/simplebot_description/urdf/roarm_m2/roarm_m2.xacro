    </geometry>
  </collision>
</link>


<link name="link4">
  <inertial>
    <origin xyz="0.024599 0 0.026788" rpy="0 0 0" />
    <mass value="0.0028708" />
    <inertia ixx="5.23216E-07" ixy="0" ixz="0" iyy="1.82071E-06" iyz="0" izz="1.60231E-06" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
