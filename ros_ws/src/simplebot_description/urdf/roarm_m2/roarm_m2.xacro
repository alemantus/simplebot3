<?xml version="1.0" ?>
<robot name="roarm_m2" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find simplebot_description)/urdf/roarm_m2/materials.xacro" />
<xacro:include filename="$(find simplebot_description)/urdf/roarm_m2/roarm_m2.trans" />
<xacro:include filename="$(find simplebot_description)/urdf/roarm_m2/roarm_m2.gazebo" />
<xacro:include filename="$(find simplebot_description)/urdf/roarm_m2/gripper.xacro" />

<!-- ===== ARM LINKS ===== -->

<link name="roarm_base_link">
  <inertial>
    <origin xyz="0.0032 0 0.04" rpy="0 0 0" />
    <mass value="0.2562183" />
    <inertia ixx="0.00029211" ixy="0" ixz="0" iyy="0.00035719" iyz="0" izz="0.000349421" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/roarm_base_link.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/roarm_base_link.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

<link name="link1">
  <inertial>
    <origin xyz="0 0 -0.015" rpy="0 0 0" />
    <mass value="0.0729177" />
    <inertia ixx="4.68465E-05" ixy="0" ixz="0" iyy="3.32107E-05" iyz="0" izz="5.01023E-05" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry> 
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link1.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link1.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

<link name="link2">
  <inertial>
    <origin xyz="0.122 0 0" rpy="0 0 0" />
    <mass value="0.0703216" />
    <inertia ixx="5.46501E-05" ixy="0" ixz="0" iyy="0.000423091" iyz="0" izz="0.000404557" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link2.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link2.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

<link name="link3">
  <inertial>
    <origin xyz="0.002 -0.13687 0.0059" rpy="0 0 0" />
    <mass value="0.0269773" />
    <inertia ixx="0.000199591" ixy="0" ixz="0" iyy="8.01674E-06" iyz="0" izz="0.000196918" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link3.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link3.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

<!-- tool0: the tool mounting frame at the end of link3.
     This is where the gripper attaches. -->
<link name="tool0" />
<link name="link5" />

<link name="link4">
  <inertial>
    <origin xyz="0.029 0.0027 -0.00078" rpy="0 0 0" />
    <mass value="0.0028708" />
    <inertia ixx="5.23216E-07" ixy="0" ixz="0" iyy="1.82071E-06" iyz="0" izz="1.60231E-06" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link4.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link4.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

<!-- ===== ARM JOINTS ===== -->

<joint name="roarm_base_link_to_link1" type="revolute">
  <origin xyz="0.0100000008759151 0 0.123059270461044" rpy="0 0 0" />
  <parent link="roarm_base_link" />
  <child link="link1" />
  <axis xyz="0 0 1" />
  <limit lower="-3.1416" upper="3.1416" effort="1000" velocity="1.0" />
</joint>

<joint name="link1_to_link2" type="revolute">
  <origin xyz="0 0 0" rpy="-1.5708 -1.5708 0" />
  <parent link="link1" />
  <child link="link2" />
  <axis xyz="0 0 1" />
  <limit lower="-1.5708" upper="1.5708" effort="1000" velocity="1.0" />
</joint>

<joint name="link2_to_link3" type="revolute">
  <origin xyz="0.236815132922094 0.0300023995170449 0" rpy="0 0 1.5708" />
  <parent link="link2" />
  <child  link="link3" />
  <axis xyz="0 0 1" />
  <limit lower="-1" upper="2.95" effort="1000" velocity="1.0" />
</joint>



<joint name="link3_to_link4" type="revolute">
  <origin xyz="-0.003266 -0.21599 -0.00560" rpy="3.1416 0 -1.5708" />
  <parent link="link3" />
  <child link="link4" />
  <axis xyz="0 0 1" />
  <limit lower="-1.5" upper="1.5" effort="10" velocity="1.0" />
</joint>

<!-- Fixed joint placing tool0 at the end of link3 (the tool mounting point) -->
<joint name="link4_to_link5" type="revolute">
  <origin xyz="0.09187 0.0079 -0.00078" rpy="0 1.5708 0" />
  <parent link="link4" />
  <child link="link5" />
  <axis xyz="0 0 1" />
  <limit lower="-1.5" upper="1.5" effort="10" velocity="1.0" />
</joint>


<joint name="link4_to_tool0" type="fixed">
  <origin xyz="0.09187 0.0079 -0.00078" rpy="0 1.5708 0" />
  <parent link="link4" />
  <child link="tool0" />
</joint>

<xacro:roarm_gripper parent="link5"/>

</robot>
