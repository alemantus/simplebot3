<?xml version="1.0" ?>
<robot name="roarm_m2" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find simplebot_description)/urdf/roarm_m2/materials.xacro" />
<xacro:include filename="$(find simplebot_description)/urdf/roarm_m2/roarm_m2.trans" />
<xacro:include filename="$(find simplebot_description)/urdf/roarm_m2/roarm_m2.gazebo" />

<link name="roarm_base_link">
  <inertial>
    <origin xyz="0.0032 0 0.04" rpy="0 0 0" />
    <mass value="0.2562183" />
    <inertia ixx="0.00029211" ixy="0" ixz="0" iyy="0.00035719" iyz="0" izz="0.000349421" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/roarm_base_link.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/roarm_base_link.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

<link name="link1">
  <inertial>
    <origin xyz="0 0 -0.015" rpy="0 0 0" />
    <mass value="0.0729177" />
    <inertia ixx="4.68465E-05" ixy="0" ixz="0" iyy="3.32107E-05" iyz="0" izz="5.01023E-05" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry> 
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link1.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link1.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

