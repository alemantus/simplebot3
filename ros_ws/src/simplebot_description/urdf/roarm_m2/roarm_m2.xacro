    <geometry>
      <mesh filename="file://$(find simplebot_description)/meshes/roarm_m2/link2.stl"  scale="1.0 1.0 1.0"/>
    </geometry>
  </collision>
</link>

<link name="link3">
  <inertial>
    <origin xyz="0.002 -0.13687 0.0059" rpy="0 0 0" />
    <mass value="0.0269773" />
    <inertia ixx="0.000199591" ixy="0" ixz="0" iyy="8.01674E-06" iyz="0" izz="0.000196918" />
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
